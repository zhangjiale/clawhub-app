<?xml version="1.0" encoding="utf-8"?>
<!--
  透明 splash icon drawable。

  用途：作为 windowSplashScreenAnimatedIcon 的值，让 Android 12+ 系统
  splash 不显示 logo（只显示 windowSplashScreenBackground 纯色）。

  为什么需要此 drawable（而不是直接删掉 windowSplashScreenAnimatedIcon
  行）：Android 12+ SplashScreen API 规定，windowSplashScreenAnimatedIcon
  未设置时会 fallback 到 android:icon（= launcher icon v4 lobster），
  重新引入"重复 logo"问题。显式指向透明 drawable = 告诉系统"我知道
  splash icon 该是什么，故意是空的"。

  无 night 变体（透明 fill 行为与 light/dark 无关）。

  Flutter SplashScreen 是唯一显示 mascot 的页面 → 跨层零重复 logo。
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@android:color/transparent"/>
</shape>