#!/bin/bash
# =============================================================================
# ClawHub Pre-Release Check v1.0
# =============================================================================
# Run before building an APK/IPA for device testing.
# Catches stale generated code, analysis errors, and test failures
# BEFORE they reach the phone.
#
# Usage:
#   ./scripts/pre-release-check          # full check
#   ./scripts/pre-release-check --quick   # skip code generation (faster)
#
# Exit code: 0 = ready to build, 1 = fix issues first
#
# Docs: CLAUDE.md, docs/engineering/iron-laws.md
# =============================================================================
set -euo pipefail

QUICK_MODE=false
if [ "${1:-}" = "--quick" ]; then
  QUICK_MODE=true
  shift
fi

# --- Colors (empty if not a terminal) ---
if [ -t 2 ]; then
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[1;33m'
  CYAN='\033[0;36m'
  BOLD='\033[1m'
  NC='\033[0m'
else
  RED='' GREEN='' YELLOW='' CYAN='' BOLD='' NC=''
fi

PASS=0
FAIL=0
WARN=0

# --- Header ---
echo ""
echo -e "${CYAN}${BOLD}╔══════════════════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}${BOLD}║          ClawHub Pre-Release Check v1.0                 ║${NC}"
echo -e "${CYAN}${BOLD}╚══════════════════════════════════════════════════════════╝${NC}"
echo ""

TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
echo -e "  Time:  ${BOLD}$TIMESTAMP${NC}"
echo -e "  Mode:  ${BOLD}$([ "$QUICK_MODE" = true ] && echo 'Quick (skip code gen)' || echo 'Full')${NC}"

# --- Helper ---
check_step() {
  local name="$1"
  local is_warning="${2:-false}"  # "true" = failure is a warning, not a block

  echo ""
  echo -e "${BOLD}━━━ $name ━━━${NC}"

  shift 2 || true
  local output
  if output=$("$@" 2>&1); then
    echo -e "  ${GREEN}✓ PASS${NC}"
    PASS=$((PASS + 1))
  else
    if [ "$is_warning" = "true" ]; then
      echo -e "  ${YELLOW}⚠ WARNING${NC}"
      echo "$output" | while IFS= read -r line; do echo -e "    ${YELLOW}$line${NC}"; done
      WARN=$((WARN + 1))
    else
      echo -e "  ${RED}✗ FAIL${NC}"
      echo "$output" | while IFS= read -r line; do echo -e "    ${RED}$line${NC}"; done
      FAIL=$((FAIL + 1))
    fi
  fi
}

# =============================================================================
# Step 1: Uncommitted changes (WARNING only — doesn't block)
# =============================================================================
echo -e "${BOLD}━━━ ① Uncommitted changes ━━━${NC}"
UNCOMMITTED=$(git diff --name-only 2>/dev/null || true)
UNSTAGED=$(git diff --staged --name-only 2>/dev/null || true)
UNTRACKED=$(git ls-files --others --exclude-standard 2>/dev/null || true)
CHANGES=""
[ -n "$UNCOMMITTED" ] && CHANGES="$CHANGES$UNCOMMITTED"$'\n'
[ -n "$UNSTAGED" ] && CHANGES="$CHANGES$UNSTAGED"$'\n'
[ -n "$UNTRACKED" ] && CHANGES="$CHANGES$UNTRACKED"$'\n'
CHANGES=$(echo "$CHANGES" | grep -v '^$' || true)

if [ -n "$CHANGES" ]; then
  CHANGE_COUNT=$(echo "$CHANGES" | wc -l)
  echo -e "  ${YELLOW}⚠ WARNING${NC} — $CHANGE_COUNT file(s) with uncommitted changes:"
  echo "$CHANGES" | head -10 | while IFS= read -r f; do
    [ -z "$f" ] && continue
    echo -e "    ${YELLOW}$f${NC}"
  done
  if [ "$CHANGE_COUNT" -gt 10 ]; then
    echo -e "    ${YELLOW}... and $((CHANGE_COUNT - 10)) more${NC}"
  fi
  echo -e "  ${YELLOW}  → Build will include uncommitted changes.${NC}"
  WARN=$((WARN + 1))
else
  echo -e "  ${GREEN}✓ PASS${NC} — Working tree clean"
  PASS=$((PASS + 1))
fi

# =============================================================================
# Step 2: Code generation freshness
# =============================================================================
if [ "$QUICK_MODE" = true ]; then
  echo ""
  echo -e "${BOLD}━━━ ② Code generation ━━━${NC}"
  echo -e "  ${YELLOW}ⓘ  Skipped (--quick mode)${NC}"
else
  echo ""
  echo -e "${BOLD}━━━ ② Code generation freshness ━━━${NC}"

  # Capture pre-build_runner state of generated files
  GEN_FILES_BEFORE=$(git diff --name-only -- '*.g.dart' '*.freezed.dart' 2>/dev/null || true)

  BUILD_OUTPUT=$(dart run build_runner build --delete-conflicting-outputs 2>&1)
  BUILD_EXIT=$?

  if [ $BUILD_EXIT -ne 0 ]; then
    echo -e "  ${RED}✗ FAIL${NC} — build_runner failed with exit code $BUILD_EXIT"
    echo "$BUILD_OUTPUT" | tail -20 | while IFS= read -r line; do
      echo -e "    ${RED}$line${NC}"
    done
    echo -e "  ${RED}  → Fix code generation errors before building.${NC}"
    FAIL=$((FAIL + 1))
  else
    # Check if build_runner generated different output than committed
    GEN_FILES_AFTER=$(git diff --name-only -- '*.g.dart' '*.freezed.dart' 2>/dev/null || true)
    NEW_GEN=$( { echo "$GEN_FILES_AFTER"; echo "$GEN_FILES_BEFORE"; } | sort | uniq -u || true)

    if [ -n "$NEW_GEN" ]; then
      echo -e "  ${RED}✗ FAIL${NC} — Generated code is stale. These files changed after build_runner:"
      echo "$NEW_GEN" | while IFS= read -r f; do
        [ -z "$f" ] && continue
        echo -e "    ${YELLOW}$f${NC}"
      done
      echo -e "  ${RED}  → Run: dart run build_runner build --delete-conflicting-outputs${NC}"
      echo -e "  ${RED}  → Then commit the updated generated files.${NC}"
      FAIL=$((FAIL + 1))
    else
      echo -e "  ${GREEN}✓ PASS${NC} — Generated code up to date"
      PASS=$((PASS + 1))
    fi
  fi
fi

# =============================================================================
# Step 3: Static analysis
# =============================================================================
check_step "③ Static analysis (flutter analyze)" "false" \
  flutter analyze --no-fatal-infos

# =============================================================================
# Step 4: Unit & Widget tests
# =============================================================================
check_step "④ Unit & Widget tests (flutter test)" "false" \
  flutter test

# =============================================================================
# Step 5: Device integration tests (requires device/emulator)
# =============================================================================
echo ""
echo -e "${BOLD}━━━ ⑤ On-device smoke test ━━━${NC}"

INTEGRATION_DIR="integration_test"
if [ -d "$INTEGRATION_DIR" ]; then
  INTEGRATION_TESTS=$(find "$INTEGRATION_DIR" -name '*_test.dart' -type f 2>/dev/null || true)
  if [ -n "$INTEGRATION_TESTS" ]; then
    echo -e "  ${YELLOW}ⓘ  On-device tests require a connected device/emulator.${NC}"
    echo -e "  ${YELLOW}  → Headless integration tests already ran in step ④.${NC}"
    echo -e "  ${YELLOW}  → To run on-device: flutter test integration_test/${NC}"
  else
    echo -e "  ${YELLOW}ⓘ  No on-device tests — headless integration tests cover critical paths${NC}"
  fi
else
  echo -e "  ${YELLOW}ⓘ  No integration_test/ directory — skipping${NC}"
  echo -e "  ${GREEN}  → Headless integration tests (test/integration/) cover critical paths${NC}"
fi

# =============================================================================
# Summary
# =============================================================================
echo ""
echo -e "${CYAN}══════════════════════════════════════════════════════════${NC}"
echo ""
TOTAL=$((PASS + FAIL))
echo -e "  ${BOLD}$TOTAL checks: ${GREEN}$PASS passed${NC}, ${RED}$FAIL failed${NC}, ${YELLOW}$WARN warning(s)${NC}"
echo ""

if [ "$FAIL" -gt 0 ]; then
  echo -e "${RED}${BOLD}  ✗ PRE-RELEASE CHECK FAILED${NC}"
  echo ""
  echo -e "  ${RED}Fix the $FAIL failing check(s) above before building.${NC}"
  echo -e "  ${RED}Re-run: ./scripts/pre-release-check${NC}"
  echo ""
  exit 1
elif [ "$WARN" -gt 0 ]; then
  echo -e "${YELLOW}${BOLD}  ⚠ PRE-RELEASE CHECK PASSED WITH WARNINGS${NC}"
  echo ""
  echo -e "  ${YELLOW}Review the $WARN warning(s) above before building.${NC}"
  echo ""
  exit 0
else
  echo -e "${GREEN}${BOLD}  ✓ ALL CHECKS PASSED${NC}"
  echo ""
  echo -e "  ${GREEN}Ready to build. Run: flutter build apk${NC}"
  echo ""
  exit 0
fi
