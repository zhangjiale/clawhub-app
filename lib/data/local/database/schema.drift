-- ============================================================
-- ClawHub Database Schema (Drift SQL-first)
-- Phase 1: Core tables for MVP repository replacement
-- Aligned with: docs/database_v3.sql (Zero-Trigger principle)
-- ============================================================

-- ============================================================
-- 1. Instances — Gateway connection configurations
-- health_status: 0=Unknown, 1=Online, 2=Offline, 3=Connecting, 4=ExpectedOffline
-- ============================================================
CREATE TABLE instances (
    id TEXT PRIMARY KEY,
    name TEXT NOT NULL UNIQUE,
    gateway_url TEXT NOT NULL,
    token_ref TEXT NOT NULL,
    health_status INTEGER DEFAULT 0,
    is_local_network INTEGER DEFAULT 0,
    last_connected_at INTEGER,
    created_at INTEGER NOT NULL
);

-- ============================================================
-- 2. Agents — Agent configs with dual-ID strategy
-- Phase 1: quick_commands_json TEXT column in lieu of separate quick_commands table
-- ============================================================
CREATE TABLE agents (
    local_id TEXT PRIMARY KEY,
    remote_id TEXT NOT NULL,
    instance_id TEXT NOT NULL,
    name TEXT NOT NULL,
    nickname TEXT,
    avatar_url TEXT,
    theme_color TEXT DEFAULT '#4F83FF', -- V2 sapphire (was V1 #007AFF)
    quick_commands_json TEXT,
    description TEXT,
    is_pinned INTEGER DEFAULT 0,
    created_at INTEGER NOT NULL,
    removed_at INTEGER, -- US-021: Gateway sync 独占写入；非空表示远端已删除（毫秒）
    hidden_at INTEGER,  -- US-021 v2 预留：用户主动隐藏；v1 不写入
    UNIQUE(instance_id, remote_id),
    FOREIGN KEY (instance_id) REFERENCES instances(id) ON DELETE CASCADE
);

-- ============================================================
-- 3. Conversations — Conversation aggregate roots
-- id = SHA256(instanceId + agentId), maintained by application layer
-- last_message_role: 0=User, 1=Agent, 2=System
-- ============================================================
CREATE TABLE conversations (
    id TEXT PRIMARY KEY,
    agent_id TEXT NOT NULL,
    instance_id TEXT NOT NULL,
    last_message_id TEXT,
    last_message_preview TEXT,
    last_message_time INTEGER DEFAULT 0,
    last_message_role INTEGER,
    unread_count INTEGER DEFAULT 0,
    is_muted INTEGER DEFAULT 0,
    FOREIGN KEY (agent_id) REFERENCES agents(local_id) ON DELETE CASCADE
);

-- ============================================================
-- 4. Messages — Message stream with dual-ID
-- role: 0=User, 1=Agent, 2=System
-- type: 0=Text, 1=Image, 2=File, 3=ToolCall
-- status: 0=Draft, 1=Pending, 2=Sending, 3=Sent, 4=Delivered, 5=Failed, 6=Expired
-- ============================================================
CREATE TABLE messages (
    rowid INTEGER PRIMARY KEY AUTOINCREMENT,
    client_id TEXT UNIQUE NOT NULL,
    server_id TEXT UNIQUE,
    conversation_id TEXT NOT NULL,
    agent_id TEXT NOT NULL,
    role INTEGER NOT NULL,
    content TEXT,
    type INTEGER NOT NULL,
    status INTEGER NOT NULL,
    logical_clock INTEGER NOT NULL,
    timestamp INTEGER NOT NULL,
    metadata TEXT,
    FOREIGN KEY (conversation_id) REFERENCES conversations(id) ON DELETE CASCADE
);

-- ============================================================
-- 5. Messages FTS — Full-text search virtual table
-- Manually synchronized by application-layer Repository
-- ============================================================
CREATE VIRTUAL TABLE messages_fts USING fts5(
    content,
    content='messages',
    content_rowid='rowid',
    tokenize='unicode61'
);

-- ============================================================
-- 6. Tool Calls — Tool call sub-entities of messages
-- status: 0=Pending, 1=Running, 2=Success, 3=Failed
-- ============================================================
CREATE TABLE tool_calls (
    id TEXT PRIMARY KEY,
    message_id TEXT NOT NULL,
    tool_name TEXT NOT NULL,
    status INTEGER NOT NULL,
    input_args TEXT,
    output_result TEXT,
    started_at INTEGER,
    ended_at INTEGER,
    FOREIGN KEY (message_id) REFERENCES messages(client_id) ON DELETE CASCADE
);

-- ============================================================
-- Indexes — Performance optimization
-- ============================================================
CREATE INDEX idx_instances_status ON instances(health_status);

CREATE INDEX idx_agents_instance ON agents(instance_id);
CREATE INDEX idx_agents_remote ON agents(instance_id, remote_id);
CREATE INDEX idx_agents_pin_name ON agents(instance_id, is_pinned DESC, name ASC);

CREATE INDEX idx_conv_time ON conversations(last_message_time DESC);
CREATE INDEX idx_conv_agent ON conversations(agent_id);

CREATE INDEX idx_msgs_conv_time ON messages(conversation_id, timestamp DESC);
CREATE INDEX idx_msgs_server ON messages(server_id);
CREATE INDEX idx_msgs_agent ON messages(agent_id);
CREATE INDEX idx_msgs_status ON messages(status);
CREATE INDEX idx_msgs_conv_clock ON messages(conversation_id, logical_clock DESC);

CREATE INDEX idx_tool_calls_msg ON tool_calls(message_id);

-- ============================================================
-- Named Queries: Instances
-- ============================================================

getAllInstances: SELECT * FROM instances ORDER BY last_connected_at DESC;

getInstanceById: SELECT * FROM instances WHERE id = :id;

-- Name existence check (with optional exclude). Returns 0 or 1 row with count.
-- :excludeId is nullable — COALESCE(NULL, '') yields '' so the OR-branch
-- is skipped and all rows (including id = '') are considered.
checkNameExists:
SELECT COUNT(*) AS cnt FROM instances
WHERE name = :name AND (COALESCE(:excludeId, '') = '' OR id != :excludeId);

upsertInstance:
INSERT INTO instances
    (id, name, gateway_url, token_ref, health_status, is_local_network, last_connected_at, created_at)
VALUES (:id, :name, :gatewayUrl, :tokenRef, :healthStatus, :isLocalNetwork, :lastConnectedAt, :createdAt)
ON CONFLICT(id) DO UPDATE SET
    name = :name,
    gateway_url = :gatewayUrl,
    token_ref = :tokenRef,
    health_status = :healthStatus,
    is_local_network = :isLocalNetwork,
    last_connected_at = :lastConnectedAt,
    created_at = :createdAt;

deleteInstanceById: DELETE FROM instances WHERE id = :id;

updateInstanceHealthStatus:
UPDATE instances SET health_status = :status WHERE id = :id;

updateInstanceLastConnectedAt:
UPDATE instances SET last_connected_at = :timestamp WHERE id = :id;

batchUpdateStatusByNetwork:
UPDATE instances SET health_status = :status WHERE is_local_network = :isLocalNetwork;

-- ============================================================
-- Named Queries: Agents
-- ============================================================

getAgentsByInstance:
SELECT * FROM agents WHERE instance_id = :instanceId ORDER BY is_pinned DESC, name ASC;

-- US-021: 默认过滤 tombstoned/hidden 的活跃 agent 查询。
-- 原 getAllAgents / getAgentsByInstance 保留不过滤版（deleteByInstanceId
-- 清理逻辑及未来"显示已移除"开关会用）。
getAllActiveAgents:
SELECT * FROM agents WHERE removed_at IS NULL AND hidden_at IS NULL ORDER BY is_pinned DESC, name ASC;

getActiveAgentsByInstance:
SELECT * FROM agents WHERE instance_id = :instanceId AND removed_at IS NULL AND hidden_at IS NULL ORDER BY is_pinned DESC, name ASC;

getAllAgents:
SELECT * FROM agents ORDER BY is_pinned DESC, name ASC;

getAgentByLocalId: SELECT * FROM agents WHERE local_id = :localId;

findAgentByCompositeKey:
SELECT * FROM agents WHERE instance_id = :instanceId AND remote_id = :remoteId;

insertAgent:
INSERT INTO agents
    (local_id, remote_id, instance_id, name, nickname, avatar_url, theme_color, quick_commands_json, description, is_pinned, created_at, removed_at, hidden_at)
VALUES (:localId, :remoteId, :instanceId, :name, :nickname, :avatarUrl, :themeColor, :quickCommandsJson, :description, :isPinned, :createdAt, :removedAt, :hiddenAt);

updateAgentFromGateway:
UPDATE agents SET name = :name, description = :description WHERE local_id = :localId;

updateAgentQuickCommands:
UPDATE agents SET quick_commands_json = :json WHERE local_id = :localId;

toggleAgentPin:
UPDATE agents SET is_pinned = CASE WHEN is_pinned = 1 THEN 0 ELSE 1 END WHERE local_id = :localId;

deleteAgentsByInstanceId: DELETE FROM agents WHERE instance_id = :instanceId;

-- ============================================================
-- Named Queries: Conversations
-- ============================================================

getConversationById: SELECT * FROM conversations WHERE id = :id;

getAllConversationsWithMessages:
SELECT * FROM conversations WHERE last_message_time > 0 ORDER BY last_message_time DESC;

insertConversation:
INSERT OR IGNORE INTO conversations
    (id, agent_id, instance_id, last_message_id, last_message_preview, last_message_time, last_message_role, unread_count, is_muted)
VALUES (:id, :agentId, :instanceId, :lastMessageId, :lastMessagePreview, :lastMessageTime, :lastMessageRole, :unreadCount, :isMuted);

updateConversationLastMessage:
UPDATE conversations SET
    last_message_id = :messageId,
    last_message_preview = :preview,
    last_message_time = :timestamp,
    last_message_role = :role
WHERE id = :conversationId;

incrementConversationUnread:
UPDATE conversations SET unread_count = unread_count + :count WHERE id = :id;

clearConversationUnread:
UPDATE conversations SET unread_count = 0 WHERE id = :id;

toggleConversationMute:
UPDATE conversations SET is_muted = CASE WHEN is_muted = 1 THEN 0 ELSE 1 END WHERE id = :id;

deleteConversationsByInstanceId: DELETE FROM conversations WHERE instance_id = :instanceId;

-- ============================================================
-- Named Queries: Messages
-- ============================================================

getMessageByClientId: SELECT * FROM messages WHERE client_id = :clientId;

getMessageByServerId: SELECT * FROM messages WHERE server_id = :serverId;

-- Returns all messages for a conversation (no cursor filter).
-- Use when before is null (the common case for first page load).
getMessagesByConversationFirst:
SELECT * FROM messages
WHERE conversation_id = :conversationId
ORDER BY logical_clock DESC
LIMIT :limit;

-- Returns messages before a given cursor (by clientId).
-- Only use when a cursor is provided.
getMessagesByConversationBefore:
SELECT * FROM messages
WHERE conversation_id = :conversationId
  AND logical_clock < (SELECT logical_clock FROM messages WHERE client_id = :before)
ORDER BY logical_clock DESC
LIMIT :limit;

-- Anchor window: messages ABOVE the target (older), by logical_clock.
-- Bounded by :limit (= before count). Uses a subquery to resolve the
-- target's logical_clock without a separate round-trip, mirroring
-- getMessagesByConversationBefore. Ordered DESC so the nearest-older
-- messages come first; the repo reverses to ASC before merging.
--
-- Bug 5 fix: <= instead of < — preserves messages with the same
-- logicalClock as the target (historical/ties treated as "before").
-- client_id exclusion prevents the target itself from being included.
getMessagesByConversationBeforeAnchor:
SELECT * FROM messages
WHERE conversation_id = :conversationId
  AND logical_clock <= (SELECT logical_clock FROM messages WHERE client_id = :targetClientId)
  AND client_id != :targetClientId
ORDER BY logical_clock DESC
LIMIT :limit;

-- Anchor window: messages BELOW the target (newer), by logical_clock.
-- Bounded by :limit (= after count). Ordered ASC nearest-newer first.
-- Uses strict > — same-clock messages are assigned to the before side
-- to avoid duplication.
getMessagesByConversationAfterAnchor:
SELECT * FROM messages
WHERE conversation_id = :conversationId
  AND logical_clock > (SELECT logical_clock FROM messages WHERE client_id = :targetClientId)
ORDER BY logical_clock ASC
LIMIT :limit;

insertMessage:
INSERT INTO messages
    (client_id, server_id, conversation_id, agent_id, role, content, type, status, logical_clock, timestamp, metadata)
VALUES (:clientId, :serverId, :conversationId, :agentId, :role, :content, :type, :status, :logicalClock, :timestamp, :metadata);

updateMessageStatusById:
UPDATE messages SET status = :status WHERE client_id = :clientId;

bindMessageServerId:
UPDATE messages SET server_id = :serverId, status = :status WHERE client_id = :clientId;

updateMessageContentTypeMetadataByServerId:
UPDATE messages SET content = :content, type = :type, metadata = :metadata WHERE server_id = :serverId;

getOutboxMessages:
SELECT * FROM messages WHERE agent_id = :agentId AND status IN (1, 5);

--- Per-instance outbox: PENDING + FAILED, ordered by logical_clock ASC for sequential flush.
--- Relies on conversations ON DELETE CASCADE to guarantee INNER JOIN never drops rows.
--- If FK strategy ever changes to SET NULL / NO ACTION, switch to LEFT JOIN.
getOutboxMessagesByInstance:
SELECT m.* FROM messages m
JOIN conversations c ON m.conversation_id = c.id
WHERE c.instance_id = :instanceId AND m.status IN (1, 5)
ORDER BY m.logical_clock ASC;

--- Per-instance outbox count (for UI warning banner, AC3: >= 20 threshold)
getOutboxCountByInstance:
SELECT COUNT(*) AS cnt FROM messages m
JOIN conversations c ON m.conversation_id = c.id
WHERE c.instance_id = :instanceId AND m.status IN (1, 5);

--- CAS conditional update: transition to SENDING only if current status matches expected.
--- Returns affected row count (0 = CAS failed = message already processed by another path).
--- Prevents TOCTOU race between SendMessageUseCase and OutboxProcessor.
tryTransitionToSending:
UPDATE messages SET status = 2 WHERE client_id = :clientId AND status = :expectedStatus;

--- Crash recovery: reset stale SENDING messages back to PENDING after app kill.
--- Bypasses FSM validation — this is crash recovery, not normal business flow.
--- Called by OutboxProcessor before each flush.
--- Scoped to a single instance via conversations JOIN to prevent cross-instance
--- race: instance B flushing must not reset instance A's in-flight SENDING messages.
---
--- server_id guard: a SENDING message that already has a server_id has been
--- ACK'd by the Gateway (bindServerId ran but the status machine didn't
--- advance to SENT before the app was killed). Resetting it to PENDING would
--- cause the next flush to re-send → server-side duplicate. Skip those.
resetStaleSending:
UPDATE messages SET status = 1
WHERE status = 2
  AND server_id IS NULL
AND conversation_id IN (
  SELECT id FROM conversations WHERE instance_id = :instanceId
);

-- FTS5-based search
searchMessages:
SELECT m.* FROM messages m
JOIN messages_fts fts ON m.rowid = fts.rowid
WHERE messages_fts MATCH :query
ORDER BY m.timestamp DESC
LIMIT :limit OFFSET :offset;

getMessageCountByAgent:
SELECT COUNT(*) AS cnt FROM messages WHERE agent_id = :agentId;

-- Delete oldest messages, keeping the most recent :keep
deleteOldMessagesByAgent:
DELETE FROM messages
WHERE agent_id = :agentId
  AND rowid NOT IN (
    SELECT rowid FROM messages WHERE agent_id = :agentId ORDER BY timestamp DESC LIMIT :keep
  );

deleteMessageByClientId: DELETE FROM messages WHERE client_id = :clientId;

-- US-020: per-agent 清空入口。删除指定 agent 的全部消息。
-- tool_calls 经 FOREIGN KEY ... ON DELETE CASCADE 级联清理（schema 第 7 行）。
-- FTS5 索引不会自动联动 messages 删除，需调用方先调 purgeMessagesFtsForAgent。
deleteMessagesByAgent: DELETE FROM messages WHERE agent_id = :agentId;

-- ============================================================
-- 7. User Preferences — Singleton global settings (one row)
-- ============================================================
CREATE TABLE user_preferences (
    id INTEGER PRIMARY KEY DEFAULT 1 CHECK(id = 1),
    notifications_enabled INTEGER NOT NULL DEFAULT 1,
    notify_on_reply INTEGER NOT NULL DEFAULT 1,
    notify_on_error INTEGER NOT NULL DEFAULT 1,
    notify_on_connection_change INTEGER NOT NULL DEFAULT 1,
    dnd_enabled INTEGER NOT NULL DEFAULT 0,
    dnd_start_hour INTEGER NOT NULL DEFAULT 22,
    dnd_start_minute INTEGER NOT NULL DEFAULT 0,
    dnd_end_hour INTEGER NOT NULL DEFAULT 8,
    dnd_end_minute INTEGER NOT NULL DEFAULT 0,
    biometric_enabled INTEGER NOT NULL DEFAULT 0,
    background_sync_enabled INTEGER NOT NULL DEFAULT 1
);

-- ============================================================
-- Named Queries: User Preferences
-- ============================================================

getUserPreferences:
SELECT * FROM user_preferences WHERE id = 1;

upsertUserPreferences:
INSERT OR REPLACE INTO user_preferences
    (id, notifications_enabled, notify_on_reply, notify_on_error,
     notify_on_connection_change, dnd_enabled, dnd_start_hour, dnd_start_minute,
     dnd_end_hour, dnd_end_minute, biometric_enabled, background_sync_enabled)
VALUES (1, :notificationsEnabled, :notifyOnReply, :notifyOnError,
        :notifyOnConnectionChange, :dndEnabled, :dndStartHour, :dndStartMinute,
        :dndEndHour, :dndEndMinute, :biometricEnabled, :backgroundSyncEnabled);

-- ============================================================
-- 8. Achievement Unlocks — per-agent unlock records
-- ============================================================
CREATE TABLE achievement_unlocks (
    achievement_id TEXT NOT NULL,
    agent_id TEXT NOT NULL,
    unlocked_at INTEGER NOT NULL,
    PRIMARY KEY (achievement_id, agent_id),
    FOREIGN KEY (agent_id) REFERENCES agents(local_id) ON DELETE CASCADE
);

-- Named queries: Achievement Unlocks
getAchievementUnlocksForAgent:
SELECT * FROM achievement_unlocks WHERE agent_id = :agentId;

insertAchievementUnlock:
INSERT OR IGNORE INTO achievement_unlocks
    (achievement_id, agent_id, unlocked_at)
VALUES (:achievementId, :agentId, :unlockedAt);

-- US-020: per-agent 清空。删除指定 agent 的全部成就解锁记录（回退为锁定态）。
deleteAchievementUnlocksForAgent:
DELETE FROM achievement_unlocks WHERE agent_id = :agentId;

-- ============================================================
-- 10. Pending Notifications — DND silenced queue (US-018 AC-3)
-- ============================================================
-- 通知命中免打扰时段时静默入队，DND 结束后批量汇总推送。
-- message_server_id 可空 (catch-up 场景部分消息无 serverId)。
-- 去重靠部分唯一索引 (在 database.dart beforeOpen 中创建，
-- WHERE message_server_id IS NOT NULL)，无 serverId 的消息不入 DB 约束。
CREATE TABLE pending_notifications (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    agent_id TEXT NOT NULL,
    instance_id TEXT NOT NULL,
    agent_name TEXT NOT NULL,
    summary TEXT NOT NULL,
    created_at INTEGER NOT NULL,
    message_server_id TEXT,
    delivered INTEGER NOT NULL DEFAULT 0 CHECK(delivered IN (0,1))
);

-- Named queries: Pending Notifications
getPendingNotifications:
SELECT * FROM pending_notifications
WHERE delivered = 0
ORDER BY created_at ASC;

countPendingNotifications:
SELECT COUNT(*) AS c FROM pending_notifications WHERE delivered = 0;

markPendingDelivered:
UPDATE pending_notifications SET delivered = 1 WHERE id = :id;

-- Batch-mark a set of ids as delivered in a single statement (Law 6).
-- Supports an arbitrary-length id list for DND summary flush without N+1.
markPendingDeliveredBatch:
UPDATE pending_notifications SET delivered = 1 WHERE id IN :ids;

deleteDeliveredNotifications:
DELETE FROM pending_notifications WHERE delivered = 1;

-- Insert ignoring (instanceId, serverId) duplicates for non-null serverId.
-- Rows with NULL message_server_id bypass the partial unique index and
-- always insert (dedup falls back to in-memory LRU in the dispatcher).
insertPendingNotification:
INSERT INTO pending_notifications
    (agent_id, instance_id, agent_name, summary, created_at, message_server_id, delivered)
VALUES (:agentId, :instanceId, :agentName, :summary, :createdAt, :messageServerId, 0)
ON CONFLICT DO NOTHING;

-- US-020: per-agent 清空。删除指定 agent 的全部 DND 静默队列条目。
-- 不清会让 DND 汇总通知引用已删除的消息（pending_notifications 无 FK 不会
-- 级联，必须显式删）。
deletePendingNotificationsForAgent:
DELETE FROM pending_notifications WHERE agent_id = :agentId;

-- ============================================================
-- 9. Background Sync State — per-(instance, agent) last sync cursor
-- ============================================================
CREATE TABLE sync_state_agent (
    instance_id     TEXT NOT NULL,
    agent_remote_id TEXT NOT NULL,
    last_sync_at    INTEGER NOT NULL,
    PRIMARY KEY (instance_id, agent_remote_id)
);

getLastSyncAt:
SELECT last_sync_at FROM sync_state_agent
WHERE instance_id = :instanceId AND agent_remote_id = :agentRemoteId;

upsertLastSyncAt:
INSERT INTO sync_state_agent (instance_id, agent_remote_id, last_sync_at)
VALUES (:instanceId, :agentRemoteId, :lastSyncAt)
ON CONFLICT(instance_id, agent_remote_id) DO UPDATE SET last_sync_at = :lastSyncAt;
